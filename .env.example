# =============================================================================
# Foundry Prototype Generator - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.
# =============================================================================

# --- Foundry API ---
FOUNDRY_API_URL=https://foundry.company.com
FOUNDRY_API_TOKEN=

# --- MCP Server: Design System ---
STORYBOOK_URL=https://storybook.company.com
NPM_REGISTRY=https://npm.company.com
NPM_TOKEN=

# --- GitHub ---
GITHUB_TOKEN=
GITHUB_ORG=company-name

# --- Azure: Container Apps ---
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
ACA_RESOURCE_GROUP=rg-prototype-generator
ACA_ENVIRONMENT=aca-env-prototypes
ACR_LOGIN_SERVER=acrprototypes.azurecr.io
ACR_USERNAME=
ACR_PASSWORD=

# --- Azure: Cleanup Function ---
AZURE_FUNCTIONS_APP=func-prototype-cleanup
